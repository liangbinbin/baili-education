#百里教学管理系统 - Docker 环境变量配置

#后端服务
NODE_ENV=production
PORT=3000

#MongoDB连接
MONGODB_URI=mongodb://mongo:27017/baili_education

#JWT配置 (必须修改)
JWT_SECRET=__REPLACE_WITH_SECURE_SECRET__
JWT_EXPIRES_IN=7d

#CORS配置 (修改为你的前端域名)
CORS_ORIGIN=http://localhost:8080

#文件上传
FILE_MAX_SIZE=10485760

#日志级别
LOG_LEVEL=info
