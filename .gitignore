# 百里教学管理系统 - .gitignore

# ==========================================
# 依赖
# ==========================================
node_modules/
package-lock.json

# ==========================================
# 环境配置（不要提交包含敏感信息的配置）
# ==========================================
.env
.env.local
.env.*.local
*.pem

# ==========================================
# 日志
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ==========================================
# 操作系统
# ==========================================
.DS_Store
Thumbs.db
Desktop.ini

# ==========================================
# IDE
# ==========================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ==========================================
# 构建产物
# ==========================================
dist/
build/
out/
*.tmp
*.bak

# ==========================================
# 测试
# ==========================================
coverage/
.nyc_output/
*.lcov

# ==========================================
# 备份文件
# ==========================================
*.backup
*.bak
app.js.backup

# ==========================================
# 上传文件（根据实际情况调整）
# ==========================================
/uploads/
/storage/
*.mp4
*.mp3
*.pdf
*.doc

# ==========================================
# 临时文件
# ==========================================
tmp/
temp/
.cache/
