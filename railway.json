{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "pkgs": ["nodejs_20"],
      "scripts": {
        "build": "cd backend && npm ci --only=production"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": "Node.js",
    "nodeVersion": "20",
    "startCommand": "cd backend && node server.js"
  }
}
