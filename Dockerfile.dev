FROM node:18-alpine

WORKDIR /app

RUN apk add --no-cache dumb-init

COPY package*.json ./
COPY backend/package*.json ./backend/
COPY frontend/ ./frontend/

RUN npm install && \
    cd backend && npm install && \
    npm cache clean --force

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--"]

CMD ["nodemon", "backend/server.js"]
